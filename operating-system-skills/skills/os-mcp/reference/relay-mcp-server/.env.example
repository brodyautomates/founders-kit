# Copy to .env for local runs. Required unless marked otherwise.

# --- Upstream Relay + PocketBase ---
RELAY_API_URL=                     # required, e.g. https://api.system3.md
PB_AUTH_URL=                       # required, e.g. https://auth.system3.md
PB_COLLECTION=users                # optional, PocketBase collection (default: users)

# --- This server ---
PUBLIC_URL=                        # set after the first deploy to the assigned domain
PORT=3000                          # optional (default: 3000)
JWT_SECRET=                        # required, >=32 chars: openssl rand -hex 32
STATIC_MCP_BEARER=                 # recommended: openssl rand -hex 24
DATA_DIR=/data                     # required, point at a mounted volume

# --- Optional ---
ALLOWED_EMAILS=                    # optional comma-separated allow-list of Relay.md emails
RELAY_AUTH_TOKEN=                  # only used by the static-bearer path (PocketBase JWT)
RELAY_ID=                          # optional vault GUID; auto-discovered per user when blank
