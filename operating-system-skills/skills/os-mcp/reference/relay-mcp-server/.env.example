# All values below are required unless noted.
RELAY_AUTH_TOKEN=                  # PocketBase JWT (only needed for static-bearer fallback)
RELAY_API_URL=                     # e.g. https://api.system3.md
RELAY_ID=                          # vault GUID (find in your Relay.md plugin's settings)
PB_AUTH_URL=                       # e.g. https://auth.system3.md
PB_COLLECTION=users                # PocketBase collection name
JWT_SECRET=                        # >=32 chars; generate with `openssl rand -hex 32`
STATIC_MCP_BEARER=                 # generate with `openssl rand -hex 24`
DATA_DIR=/data                     # mount a Railway volume here
PUBLIC_URL=                        # set after first deploy to the Railway-assigned domain
ALLOWED_EMAILS=                    # optional comma-separated allow-list
PORT=3000
